NEXT_PUBLIC_APP_URL=http://localhost:3000
POSTGRES_PORT=54322
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/cardinalxchange
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/cardinalxchange
OPENAI_API_KEY=

# Better Auth
# BETTER_AUTH_SECRET — generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Stanford SSO (placeholders — fill in once IT shares real metadata)
# Better Auth's SSO plugin lands later; these vars stay empty in dev.
STANFORD_SAML_ENTITY_ID=
STANFORD_SAML_SSO_URL=
STANFORD_SAML_CERT=
STANFORD_OIDC_ISSUER=
STANFORD_OIDC_CLIENT_ID=
STANFORD_OIDC_CLIENT_SECRET=

# Magic-link email transport (Mailtrap / Postmark / SES in prod).
# In development the magic link is logged to the server console, so
# these can stay empty.
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=no-reply@cardinalxchange.local

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum QuestionStatus {
  OPEN
  ANSWERED
  ACCEPTED
}

enum UserRole {
  STUDENT
  MODERATOR
}

enum AiChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AiChatSourceKind {
  INTERNAL_QUESTION
  INTERNAL_ANSWER
  WEB
}

model Question {
  id             String           @id @default(cuid())
  slug           String           @unique
  title          String           @db.VarChar(180)
  body           String
  authorId       String?
  author         User?            @relation("UserQuestions", fields: [authorId], references: [id], onDelete: SetNull)
  authorName     String           @db.VarChar(80)
  authorMeta     String?          @db.VarChar(120)
  status         QuestionStatus   @default(OPEN)
  searchText     String           @default("")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  lastActivityAt DateTime         @default(now())
  answers        Answer[]
  tags           QuestionTag[]
  aiChatSources  AiChatSource[]   @relation("AiChatSourceQuestion")

  @@index([status, lastActivityAt])
  @@index([createdAt])
  @@index([lastActivityAt])
  @@index([authorId])
}

model Answer {
  id            String             @id @default(cuid())
  questionId    String
  question      Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  body          String
  authorId      String?
  author        User?              @relation("UserAnswers", fields: [authorId], references: [id], onDelete: SetNull)
  authorName    String             @db.VarChar(80)
  authorMeta    String?            @db.VarChar(120)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  aiChatSources AiChatSource[]     @relation("AiChatSourceAnswer")

  @@index([questionId, createdAt])
  @@index([authorId])
}

model Tag {
  id        String        @id @default(cuid())
  slug      String        @unique
  label     String        @db.VarChar(80)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  questions QuestionTag[]

  @@index([label])
}

model QuestionTag {
  questionId String
  tagId      String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@index([tagId])
}

model AiChatSession {
  id         String          @id @default(cuid())
  title      String?         @db.VarChar(180)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  messages   AiChatMessage[]
  sources    AiChatSource[]

  @@index([createdAt])
}

model AiChatMessage {
  id         String          @id @default(cuid())
  sessionId  String
  session    AiChatSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role       AiChatRole
  uiMessageId String?        @db.VarChar(120)
  content    String
  parts      Json            @default("[]")
  model      String?         @db.VarChar(120)
  confidence Float?
  createdAt  DateTime        @default(now())
  sources    AiChatSource[]

  @@index([sessionId, createdAt])
  @@index([role, createdAt])
  @@index([uiMessageId])
}

model AiChatSource {
  id               String           @id @default(cuid())
  sessionId        String
  messageId        String?
  kind             AiChatSourceKind
  title            String           @db.VarChar(240)
  url              String?          @db.VarChar(500)
  snippet          String
  sourceQuestionId String?
  sourceAnswerId   String?
  createdAt        DateTime         @default(now())
  session          AiChatSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message          AiChatMessage?   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  sourceQuestion   Question?        @relation("AiChatSourceQuestion", fields: [sourceQuestionId], references: [id], onDelete: SetNull)
  sourceAnswer     Answer?          @relation("AiChatSourceAnswer", fields: [sourceAnswerId], references: [id], onDelete: SetNull)

  @@index([sessionId])
  @@index([messageId])
  @@index([sourceQuestionId])
  @@index([sourceAnswerId])
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  emailVerified DateTime?
  name          String?    @db.VarChar(120)
  displayName   String?    @db.VarChar(80)
  image         String?    @db.VarChar(500)
  role          UserRole   @default(STUDENT)
  deletedAt     DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  questions     Question[] @relation("UserQuestions")
  answers       Answer[]   @relation("UserAnswers")

  @@index([email])
  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
